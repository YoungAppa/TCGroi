# Monorepo: patterns are unanchored so they apply in every workspace.

# dependencies
node_modules/
.pnp
.pnp.*

# testing
coverage/

# next.js
.next/
out/

# builds
build/
*.tsbuildinfo
next-env.d.ts

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — secrets stay local; the documented template is committed.
.env*
!.env.example

# vercel
.vercel
