# ---------------------------------------------------------------------------
# Required. The app boots and renders with ONLY these two set: every price
# source below is optional and self-disables when unconfigured.
# ---------------------------------------------------------------------------
DATABASE_URL=postgres://user:password@host:5432/packroi
ADMIN_SECRET=change-me-to-something-long

# ---------------------------------------------------------------------------
# Deployment (production). Needed for the scheduled data refreshes and correct
# canonical URLs; omit for pure local dev.
# ---------------------------------------------------------------------------
# CRON_SECRET: the bearer token Vercel Cron sends to /api/cron/*. Set the SAME
# value here and in the Vercel project so the cron jobs authorize. (ADMIN_SECRET
# also works, for manual /admin triggers.) Absent => cron endpoints reject all.
# CRON_SECRET=change-me-to-something-long
# Public base URL — canonical links, sitemap, robots, OpenGraph. Set to your
# real domain at deploy (falls back to https://packroi.vercel.app).
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ---------------------------------------------------------------------------
# Optional — tcgplayer_market adapter.
# TCGplayer's own API is closed to new developers and their ToS forbids
# scraping, so market prices come from a third-party mirror. Provider is
# swappable; the adapter interface does not change.
#   pokemontcg_io (default; free, keyless, Pokemon only)
#   scrydex       (paid, from $29/mo; adds One Piece, graded, sealed —
#                  needs BOTH the api key below and SCRYDEX_TEAM_ID.
#                  Run scripts/probe-scrydex.ts once before first use.)
# ---------------------------------------------------------------------------
# TCGPLAYER_MIRROR_PROVIDER=scrydex
# TCGPLAYER_MIRROR_API_KEY=
# SCRYDEX_TEAM_ID=
# Optional. Raises pokemontcg.io's rate limit for the default (free) provider.
# POKEMONTCG_IO_KEY=

# ---------------------------------------------------------------------------
# Optional — pricecharting_ebay adapter. Paid subscription token.
# Our eBay-sold source, our best sealed-product price source, and (for Magic +
# One Piece + Chinese Pokemon) a card price source. Absent => adapter disabled.
# ---------------------------------------------------------------------------
# PRICECHARTING_TOKEN=

# ---------------------------------------------------------------------------
# Optional — pokeprice_ebay (graded). PokemonPriceTracker API key: adds PSA 10
# and PSA 9 graded sale prices (Pokemon only). Absent => graded mode hidden.
# Fetched by the budget-aware scripts/refresh-graded.ts job, not the main refresh.
# ---------------------------------------------------------------------------
# POKEPRICE_TOKEN=

# ---------------------------------------------------------------------------
# Tunables
# ---------------------------------------------------------------------------
# Cards below this price contribute a flat bulk value rather than their listed
# price — matches the reality that you cannot sell $0.20 cards individually.
BULK_THRESHOLD_CENTS=50
# Graded-price refresh (scripts/refresh-graded.ts) budget knobs — all optional,
# all have code defaults. Only relevant when POKEPRICE_TOKEN is set.
# GRADED_MIN_RAW=2500        # only grade cards whose raw price is >= this (cents)
# GRADED_CARDS=30            # max cards graded per run
# GRADED_CREDIT_CAP=60       # max API credits to spend per run
# GRADED_REFRESH_DAYS=30     # skip cards graded within this many days

# ---------------------------------------------------------------------------
# Optional — affiliate. Link structure supports these; nothing requires them.
# ---------------------------------------------------------------------------
# AFFILIATE_TCGPLAYER_ID=
# AFFILIATE_EBAY_CAMPAIGN=
